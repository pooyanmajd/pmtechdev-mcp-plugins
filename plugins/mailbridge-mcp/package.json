{
  "name": "mailbridge-mcp",
  "version": "0.1.0",
  "description": "A local, safety-first MCP server for Apple Mail on macOS",
  "homepage": "https://github.com/pooyanmajd/pmtechdev-mcp-plugins/tree/main/plugins/mailbridge-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pooyanmajd/pmtechdev-mcp-plugins.git",
    "directory": "plugins/mailbridge-mcp"
  },
  "bugs": {
    "url": "https://github.com/pooyanmajd/pmtechdev-mcp-plugins/issues"
  },
  "author": "PMTechDev (Pooyan Majd) <pooyanmjd@gmail.com>",
  "type": "module",
  "bin": {
    "mailbridge-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "runtime",
    ".codex-plugin",
    ".mcp.json",
    "skills",
    "assets",
    "docs",
    "LICENSE",
    "README.md",
    "NOTICE"
  ],
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node --eval \"import('node:fs/promises').then(({rm}) => Promise.all([rm('dist', { recursive: true, force: true }), rm('coverage', { recursive: true, force: true })]))\"",
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "validate:package": "node scripts/validate-package.mjs",
    "check": "npm run lint && npm run typecheck && npm test && npm run build && npm run validate:package",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "apple-mail",
    "mail",
    "macos",
    "mcp",
    "model-context-protocol"
  ],
  "license": "MIT",
  "devDependencies": {
    "@pmtechdev/mcp-kit": "0.1.0",
    "@eslint/js": "9.39.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/node": "24.10.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.2",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10",
    "zod": "4.4.3"
  }
}
