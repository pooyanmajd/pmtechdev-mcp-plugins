  "license": "MIT",
  "keywords": ["mcp", "pmtechdev"],
  "mcpServers": {
    "__PLUGIN_NAME__": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/cli.js"]
    }
  }
}
