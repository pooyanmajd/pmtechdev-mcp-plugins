{
  "name": "pmtechdev-mcp-plugins",
  "version": "0.1.1",
  "private": true,
  "description": "PMTechDev monorepo and Codex marketplace for reusable MCP servers and plugins",
  "homepage": "https://github.com/pooyanmajd/pmtechdev-mcp-plugins#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pooyanmajd/pmtechdev-mcp-plugins.git"
  },
  "author": "PMTechDev (Pooyan Majd) <pooyanmjd@gmail.com>",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "validate:plugins": "npm run validate:package --workspaces --if-present",
    "validate:workspace": "node scripts/validate-workspace.mjs",
    "check": "npm run lint && npm run typecheck && npm test && npm run build && npm run validate:plugins && npm run validate:workspace",
    "create:plugin": "node scripts/create-plugin.mjs"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "24.10.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.2",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
